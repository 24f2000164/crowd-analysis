# =============================================================================
# Real-Time Crowd Behavior Analysis System — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your environment.
#
#   cp .env.example .env
#
# Rules:
#   - Never commit a populated .env to version control.
#   - All variables are OPTIONAL — built-in defaults are documented below.
#   - Nested settings are identified by their prefix (VIDEO_, DETECTION_, …).
#   - Booleans accept: true / false / 1 / 0 (case-insensitive).
#   - Lists are comma-separated strings, e.g.  API_CORS_ORIGINS=http://localhost:3000,https://prod.example.com
# =============================================================================


# -----------------------------------------------------------------------------
# Application — top-level
# -----------------------------------------------------------------------------

# Human-readable service name shown in logs and API responses.
APP_NAME="Crowd Analysis System"

# Semantic version string.
APP_VERSION="1.0.0"

# Runtime environment.  One of: development | staging | production
# In production, extra safety checks are enforced (see settings.py).
ENVIRONMENT=development

# Enable debug mode.  MUST be false in production.
DEBUG=false

# Root Python logging level.  One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# PyTorch inference device.  One of: cpu | cuda | mps
# Use 'cuda' for NVIDIA GPU, 'mps' for Apple Silicon, 'cpu' as fallback.
DEVICE=cpu


# -----------------------------------------------------------------------------
# Video source  (prefix: VIDEO_)
# -----------------------------------------------------------------------------

# Primary video source.  Accepted formats:
#   Webcam index  : 0
#   RTSP stream   : rtsp://username:password@192.168.1.10:554/stream1
#   Local file    : /data/recordings/sample.mp4
#   HTTP stream   : http://192.168.1.20:8080/video
VIDEO_SOURCE=0

# Source type hint used by the capture layer.
# One of: webcam | rtsp | file | http
VIDEO_SOURCE_TYPE=webcam

# Capture resolution (pixels).
VIDEO_FRAME_WIDTH=1280
VIDEO_FRAME_HEIGHT=720

# Target processing frame-rate.  Frames are dropped from the ring buffer
# when the pipeline cannot keep up.
VIDEO_TARGET_FPS=25

# Ring-buffer capacity.  Increase for bursty sources; decrease to save RAM.
VIDEO_FRAME_BUFFER_SIZE=32

# RTSP reconnection behaviour.  Set VIDEO_RTSP_RECONNECT_ATTEMPTS=0 to disable.
VIDEO_RTSP_RECONNECT_ATTEMPTS=5
VIDEO_RTSP_RECONNECT_DELAY_S=2.0

# JPEG quality for frames transmitted over WebSocket (1–100).
# Lower values reduce bandwidth; 80–90 is a good balance.
VIDEO_OUTPUT_JPEG_QUALITY=85


# -----------------------------------------------------------------------------
# Detection — YOLOv8  (prefix: DETECTION_)
# -----------------------------------------------------------------------------

# Minimum confidence score to keep a detection (0.01–1.0).
# Lower = more detections but more false positives.
DETECTION_CONFIDENCE_THRESHOLD=0.45

# IoU threshold for Non-Maximum Suppression (0.01–1.0).
DETECTION_IOU_THRESHOLD=0.45

# COCO class IDs to retain.  0 = person.  Comma-separated.
DETECTION_TARGET_CLASSES=[0]

# Square input resolution for YOLO (must be a multiple of 32).
# Options: 320, 416, 512, 640, 768, 1024, 1280
# Larger = more accurate but slower.
DETECTION_INPUT_IMAGE_SIZE=640

# Use FP16 (half-precision) inference.  Only effective on CUDA devices.
DETECTION_HALF_PRECISION=true

# Hard cap on detections returned per frame.
DETECTION_MAX_DETECTIONS=300


# -----------------------------------------------------------------------------
# Tracking — DeepSORT  (prefix: TRACKING_)
# -----------------------------------------------------------------------------

# Frames a track can remain unmatched before being deleted.
TRACKING_MAX_AGE=30

# Consecutive detections required before a track transitions to 'Confirmed'.
TRACKING_MIN_HITS=3

# IoU threshold used in the Hungarian assignment step.
TRACKING_IOU_THRESHOLD=0.3

# Cosine distance threshold for appearance-based re-identification.
# Lower = stricter matching; 0.2–0.5 is typical.
TRACKING_MAX_COSINE_DISTANCE=0.4

# Maximum gallery size per track for the nearest-neighbour re-ID metric.
TRACKING_NN_BUDGET=100

# Rolling window length (frames) for trajectory history per track.
TRACKING_TRAJECTORY_HISTORY_LENGTH=60

# Exponential Moving Average smoothing factor for velocity (0 = no smoothing).
TRACKING_VELOCITY_SMOOTHING_ALPHA=0.3

# Speed (pixels/frame) above which a track is considered 'running'.
TRACKING_SPEED_RUN_THRESHOLD_PX_PER_FRAME=15.0

# Z-score deviation from crowd mean velocity to flag a track as anomalous.
TRACKING_ANOMALY_ZSCORE_THRESHOLD=2.5


# -----------------------------------------------------------------------------
# Model weights  (prefix: MODEL_)
# -----------------------------------------------------------------------------

# Root directory that contains all weight files.
MODEL_BASE_DIR=models

# YOLOv8 checkpoint path.
# Available sizes (accuracy ↑, speed ↓): yolov8n | yolov8s | yolov8m | yolov8l | yolov8x
# Run `python scripts/download_models.py` to fetch the default weights.
MODEL_YOLO_WEIGHTS=models/yolov8n.pt

# OSNet re-identification encoder checkpoint path.
MODEL_REID_WEIGHTS=models/osnet_x0_25_msmt17.pt


# -----------------------------------------------------------------------------
# Behaviour analysis  (prefix: BEHAVIOR_)
# -----------------------------------------------------------------------------

# Grid dimensions for zone-based crowd density analysis.
BEHAVIOR_DENSITY_ZONE_ROWS=4
BEHAVIOR_DENSITY_ZONE_COLS=4

# Persons-per-zone count that triggers a density alert.
BEHAVIOR_DENSITY_ALERT_THRESHOLD=10

# Fraction of confirmed tracks that must be anomalous to fire a PANIC event.
BEHAVIOR_PANIC_MIN_ANOMALOUS_FRACTION=0.4

# Pixel proximity within which two anomalous tracks are classified as fighting.
BEHAVIOR_FIGHT_PROXIMITY_PX=80.0

# Multiplier: crowd mean speed must exceed (baseline × this) to trigger CROWD_SURGE.
BEHAVIOR_SURGE_VELOCITY_MULTIPLIER=2.0

# Minimum seconds between consecutive alerts of the same type (cool-down).
BEHAVIOR_ALERT_COOLDOWN_S=5.0


# -----------------------------------------------------------------------------
# API — FastAPI / WebSocket  (prefix: API_)
# -----------------------------------------------------------------------------

# Uvicorn bind address and port.
API_HOST=0.0.0.0
API_PORT=8000

# Number of Uvicorn workers.  Keep at 1 for development; use 1 per stream in prod.
API_WORKERS=1

# WebSocket keepalive settings (seconds).
API_WS_PING_INTERVAL_S=20.0
API_WS_PING_TIMEOUT_S=10.0

# Maximum frames queued per WebSocket connection before oldest are dropped.
API_WS_MAX_QUEUE=32

# Static API key for WebSocket authentication.
# Leave blank / unset to disable auth (development only).
# MUST be set in production (enforced by settings validator).
# API_API_KEY=change-me-to-a-long-random-string

# Comma-separated allowed CORS origins.
# Development default '*' is blocked in production by the settings validator.
API_CORS_ORIGINS=*
# Production example:
# API_CORS_ORIGINS=https://dashboard.example.com,https://admin.example.com

# Expose a Prometheus /metrics endpoint.
API_ENABLE_PROMETHEUS=true


# -----------------------------------------------------------------------------
# Storage  (prefix: STORAGE_)
# -----------------------------------------------------------------------------

# Async SQLAlchemy database URL.
# SQLite  (development)  : sqlite+aiosqlite:///./crowd_events.db
# Postgres (production)  : postgresql+asyncpg://user:password@host:5432/crowd_db
STORAGE_DATABASE_URL=sqlite+aiosqlite:///./crowd_events.db

# Events older than this many days are automatically pruned.
STORAGE_EVENT_RETENTION_DAYS=30

# Log all SQL statements to stdout.  Keep false in production.
STORAGE_ECHO_SQL=false
